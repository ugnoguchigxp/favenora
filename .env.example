# Application
NODE_ENV=development
PORT=3000
# Required when AUTH_MODE is "oauth" or "both"
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
COOKIE_SAME_SITE=lax # "none" requires secure cookies (HTTPS APP_URL or production)
TRUST_PROXY=false
VITE_ENABLE_MSW=false
LOG_LEVEL=info
AUTH_MODE=both

# gxp-idProvider (OIDC BFF / resource-server client)
# Set all four required values together to enable `/api/identity/*`.
# GXP_IDP_ISSUER=http://localhost:3001
# GXP_IDP_CLIENT_ID=local-client
# GXP_IDP_CLIENT_SECRET=local-client-secret
# GXP_IDP_REDIRECT_URI=http://localhost:3000/api/identity/callback
# GXP_IDP_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
# GXP_IDP_AUDIENCE=local-client
# GXP_IDP_SCOPES=openid profile email
# GXP_IDP_TIMEOUT_MS=3000

# Stripe payments
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_SUCCESS_URL=http://localhost:5173/payments/success
# STRIPE_CANCEL_URL=http://localhost:5173/payments/cancel
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard/billing

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:12345/favenora

# Security (JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth Providers
# If AUTH_MODE is "oauth", configure at least one provider pair.
# If AUTH_MODE is "both", configure when OAuth login is enabled.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "off",
        "noUnknownAtRules": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["designSystem/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noUnknownAtRules": "off"
          },
          "a11y": {
            "useButtonType": "off"
          },
          "complexity": {
            "noBannedTypes": "off",
            "useArrowFunction": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          },
          "style": {
            "useTemplate": "off"
          }
        }
      },
      "formatter": {
        "enabled": false
      }
    }
  ],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "api/**",
      "src/**",
      "!**/src/routeTree.gen.ts",
      "shared/**",
      "tests/**",
      "designSystem/src/**",
      "designSystem/scripts/**",
      "designSystem/pencil/scripts/**",
      "package.json",
      "tsconfig.json",
      "vite.config.ts",
      "vitest.config.ts",
      "playwright.config.ts"
    ]
  }
}
